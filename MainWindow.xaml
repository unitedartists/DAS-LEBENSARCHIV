<Window x:Class="DAS_LEBENSARCHIV.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DAS_LEBENSARCHIV"
        Title="DAS LEBENSARCHIV"
        Height="850"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Closing="MainWindow_Closing"
        KeyDown="MainWindow_KeyDown">

    <DockPanel>

        <!-- Menü -->
        <Menu DockPanel.Dock="Top">

            <MenuItem Header="Datei">
                <MenuItem Header="Neues Archiv"/>
                <MenuItem Header="Archiv öffnen"/>
                <Separator/>
                <MenuItem Header="Speichern"/>
                <Separator/>
                <MenuItem Header="Beenden"/>
            </MenuItem>

            <MenuItem Header="Personen"/>
            <MenuItem Header="Ereignisse"/>
            <MenuItem Header="Dokumente"/>
            <MenuItem Header="Erinnerungen"/>

            <MenuItem Header="Werkzeuge">
                <MenuItem Header="Computer kennenlernen" Click="WerkzeugeMenuComputerKennenlernen_Click"/>
                <MenuItem Header="Erinnerungen aufräumen" Click="WerkzeugeMenuErinnerungenAufraeumen_Click"/>
            </MenuItem>

            <MenuItem Header="Suche"/>
            <MenuItem Header="Einstellungen" Click="MenuEinstellungen_Click"/>
            <MenuItem Header="Hilfe"/>

        </Menu>

        <!-- Build 1.7: James macht Vorschläge - ganz oben, noch vor dem
             Suchfeld. Niemals als Popup, niemals aufdringlich. James
             entscheidet nicht, er schlägt nur vor - deshalb jederzeit
             über "Schließen" ausblendbar. -->
        <Border
            DockPanel.Dock="Top"
            Name="VorschlaegePanel"
            Background="#F0F7EE"
            BorderBrush="#CFE3C8"
            BorderThickness="0,0,0,1"
            Padding="20,14,20,14"
            Visibility="Collapsed">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">

                    <TextBlock
                        Name="VorschlaegeUeberschriftText"
                        FontWeight="Bold"
                        TextWrapping="Wrap"
                        Margin="0,0,0,8"/>

                    <ListBox
                        Name="VorschlaegeListe"
                        Background="Transparent"
                        BorderThickness="0"
                        SelectionChanged="VorschlaegeListe_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock
                                    Text="{Binding}"
                                    TextWrapping="Wrap"
                                    MaxWidth="700"
                                    Margin="0,2,0,2"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                </StackPanel>

                <Button
                    Grid.Column="1"
                    Content="Schließen"
                    VerticalAlignment="Top"
                    Padding="10,4"
                    Click="VorschlaegeSchliessen_Click"/>

            </Grid>

        </Border>

        <!-- James-Suche: immer sichtbar, ueber allen Reitern (Build 0.8) -->
        <!-- Build 1.6: Trefferliste links, Erinnerungskarte rechts daneben -->
        <Border
            DockPanel.Dock="Top"
            Background="#F5F5F5"
            BorderBrush="#DDDDDD"
            BorderThickness="0,0,0,1"
            Padding="20,14,20,14">

            <StackPanel>

                <TextBlock
                    FontWeight="Bold"
                    FontSize="16"
                    Margin="0,0,0,8"
                    Text="James, woran möchten Sie sich heute erinnern?"/>

                <TextBox
                    Name="JamesSucheTextBox"
                    Padding="6"
                    FontSize="14"
                    TextChanged="JamesSucheTextBox_TextChanged"/>

                <!-- Build 6.0, Punkt 7: Rahmen für Start/Abbrechen einer Suche.
                     Die Suche selbst arbeitet weiterhin synchron (blitzschnell) -
                     "Suche abbrechen" ist deshalb bewusst ohne Funktion. Die
                     Oberfläche ist damit aber bereits vorbereitet für spätere,
                     länger laufende Suchvorgänge (z.B. Bildanalyse). -->
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Button
                        Name="SucheStartenButton"
                        Content="Suche starten"
                        Width="140"
                        Height="32"
                        Margin="0,0,10,0"
                        Click="SucheStarten_Click"/>
                    <Button
                        Name="SucheAbbrechenButton"
                        Content="Suche abbrechen"
                        Width="140"
                        Height="32"
                        IsEnabled="False"
                        Click="SucheAbbrechen_Click"/>
                </StackPanel>

                <Grid Margin="0,10,0,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">

                        <ListBox
                            Name="JamesTrefferListe"
                            MaxHeight="220"
                            Visibility="Collapsed"
                            SelectionChanged="JamesTrefferListe_SelectionChanged"/>

                        <TextBlock
                            Name="JamesSucheStatusText"
                            Margin="0,8,0,0"
                            TextWrapping="Wrap"
                            Foreground="#555555"/>

                    </StackPanel>

                    <!-- Erinnerungskarte (Build 1.6): erscheint, sobald eine gefundene
                         Erinnerung in der Liste links angeklickt wird. Bewusst
                         großzügig gestaltet - bildet später die Grundlage für das
                         Lebensbuch. Zeigt ausschließlich bereits vorhandene Daten,
                         keine neuen Felder. -->
                    <Border
                        Grid.Column="2"
                        Name="ErinnerungskartePanel"
                        Visibility="Collapsed"
                        Background="White"
                        BorderBrush="#DDDDDD"
                        BorderThickness="1"
                        Padding="20">

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border
                                Grid.Column="0"
                                BorderBrush="#CCCCCC"
                                BorderThickness="1"
                                Width="150"
                                Height="150"
                                VerticalAlignment="Top">
                                <Image
                                    Name="ErinnerungskarteBild"
                                    Stretch="Uniform"/>
                            </Border>

                            <StackPanel Grid.Column="2">

                                <TextBlock
                                    Name="ErinnerungskarteTitelText"
                                    FontSize="18"
                                    FontWeight="Bold"
                                    TextWrapping="Wrap"
                                    Margin="0,0,0,10"/>

                                <TextBlock
                                    Name="ErinnerungskarteDatumText"
                                    Margin="0,0,0,4"/>

                                <TextBlock
                                    Name="ErinnerungskartePersonText"
                                    Margin="0,0,0,4"/>

                                <TextBlock
                                    Name="ErinnerungskarteOrtText"
                                    Margin="0,0,0,4"/>

                                <TextBlock
                                    Name="ErinnerungskarteStichwoerterText"
                                    TextWrapping="Wrap"
                                    Margin="0,0,0,4"/>

                                <TextBlock
                                    Name="ErinnerungskarteBewertungenText"
                                    TextWrapping="Wrap"
                                    Margin="0,0,0,4"/>

                                <TextBlock
                                    Name="ErinnerungskarteBeteiligteText"
                                    TextWrapping="Wrap"
                                    Margin="0,0,0,4"/>

                                <TextBlock
                                    Name="ErinnerungskarteBemerkungenText"
                                    TextWrapping="Wrap"
                                    Foreground="#555555"
                                    Margin="0,8,0,0"/>

                                <TextBlock
                                    Name="ErinnerungskarteWeitereFotosText"
                                    TextWrapping="Wrap"
                                    Foreground="#777777"
                                    FontStyle="Italic"
                                    Margin="0,4,0,0"/>

                                <!-- Build 1.8: Erinnerungen verknüpfen -->
                                <StackPanel
                                    Name="ErinnerungskarteVerknuepfungenPanel"
                                    Visibility="Collapsed"
                                    Margin="0,14,0,0">

                                    <TextBlock
                                        Text="Dazu könnten auch gehören"
                                        FontWeight="Bold"
                                        Margin="0,0,0,6"/>

                                    <ListBox
                                        Name="ErinnerungskarteVerknuepfungenListe"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        MaxHeight="140"
                                        SelectionChanged="ErinnerungskarteVerknuepfungenListe_SelectionChanged">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock
                                                    Text="{Binding}"
                                                    TextWrapping="Wrap"
                                                    Margin="0,2,0,2"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                </StackPanel>

                            </StackPanel>

                        </Grid>

                    </Border>

                    <TextBlock
                        Grid.Column="2"
                        Name="ErinnerungskartePlatzhalterText"
                        Visibility="Collapsed"
                        FontStyle="Italic"
                        Foreground="#999999"
                        TextWrapping="Wrap"
                        VerticalAlignment="Top"
                        Text="Wählen Sie eine gefundene Erinnerung aus der Liste aus, um sie hier anzusehen."/>

                </Grid>

            </StackPanel>

        </Border>

        <!-- Die sechs Bereiche -->
        <TabControl Name="HauptTabControl" SelectionChanged="HauptTabControl_SelectionChanged">

            <TabItem Header="Schreibtisch">

                <Grid Margin="40">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Build 5.1: Die Startseite - zentraler Einstiegspunkt des
                         Lebensarchivs. Der Benutzer trifft hier morgens genau
                         eine Entscheidung ("Womit möchten wir uns heute
                         beschäftigen?"), James stellt anschließend die passende
                         Arbeitsumgebung bereit. -->
                    <StackPanel
                        Name="StartseiteBereich"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Visibility="Visible"
                        MaxWidth="500"
                        HorizontalAlignment="Left">

                        <TextBlock
                            Name="JamesNameText"
                            FontSize="22"
                            FontWeight="Bold"
                            Margin="0,0,0,20"
                            Text="Butler James:"/>

                        <!-- Build 6.0: der aktuelle Vorschlag (wiederverwendet aus
                             der bestehenden Vorschlags-Logik, Build 1.7 ff.) - nur
                             sichtbar, wenn James tatsächlich etwas vorzuschlagen
                             hat. James erzeugt hier keine eigenen Ereignisse und
                             erfindet nichts - er zeigt lediglich, worum sich der
                             Benutzer selbst schon einmal gekümmert hat. -->
                        <StackPanel Name="StartseiteVorschlagPanel" Visibility="Collapsed" Margin="0,0,0,24">

                            <TextBlock
                                Name="StartseiteVorschlagGrussText"
                                FontSize="15"
                                TextWrapping="Wrap"
                                Foreground="#555555"
                                Margin="0,0,0,10"/>

                            <TextBlock
                                Name="StartseiteVorschlagText"
                                FontSize="15"
                                TextWrapping="Wrap"
                                Margin="0,0,0,14"/>

                            <Button
                                Content="Vorschlag annehmen"
                                Width="220"
                                Height="40"
                                HorizontalAlignment="Left"
                                Click="VorschlagAnnehmen_Click"/>

                        </StackPanel>

                        <TextBlock
                            Name="JamesBegruessungText"
                            FontSize="16"
                            FontWeight="Bold"
                            TextWrapping="Wrap"
                            Margin="0,0,0,16"
                            Text="Womit möchten Sie sich heute lieber beschäftigen?"/>

                        <Button
                            Content="Person"
                            Width="300"
                            Height="44"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,10"
                            Click="StartseitePersonButton_Click"/>

                        <Button
                            Content="Ereignis"
                            Width="300"
                            Height="44"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,20"
                            Click="StartseiteEreignisButton_Click"/>

                        <Separator Margin="0,0,0,20"/>

                        <Button Content="Dokumente" Width="300" Height="40" HorizontalAlignment="Left" Margin="0,0,0,8" IsEnabled="False"/>
                        <Button Content="Erinnerungen durchsuchen" Width="300" Height="40" HorizontalAlignment="Left" Margin="0,0,0,8" IsEnabled="False"/>
                        <Button Content="Letzte Arbeit fortsetzen" Width="300" Height="40" HorizontalAlignment="Left" IsEnabled="False"/>

                    </StackPanel>

                    <!-- Build 5.1: Ereignisverwaltung - dieselbe Bedienlogik wie
                         die Personenverwaltung, nur für freie (personenunabhängige)
                         Ereignisse. James macht keinerlei Namensvorschläge. -->
                    <Grid
                        Name="EreignisBereich"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Visibility="Collapsed">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="360"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">

                            <TextBlock
                                Text="◀ Zur Startseite"
                                Foreground="#2E7D32"
                                FontWeight="Bold"
                                TextDecorations="Underline"
                                Cursor="Hand"
                                Margin="0,0,0,24"
                                MouseLeftButtonUp="ZurStartseite_Click"/>

                            <TextBlock Text="Ereignis" Margin="0,0,0,4"/>
                            <TextBox
                                Name="EreignisTitelSchreibtischTextBox"
                                Padding="4"
                                Margin="0,0,0,16"/>

                            <Button
                                Name="EreignisSchreibtischSpeichernButton"
                                Content="Speichern"
                                Width="140"
                                Height="40"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,20"
                                Click="EreignisSchreibtischSpeichern_Click"/>

                            <TextBlock
                                Name="FreiesEreignisErinnerungenLinkText"
                                Foreground="#2E7D32"
                                FontWeight="Bold"
                                TextDecorations="Underline"
                                Cursor="Hand"
                                Margin="0,0,0,10"
                                Visibility="Collapsed"
                                MouseLeftButtonUp="FreiesEreignisErinnerungenLinkText_MouseLeftButtonUp"/>

                            <Button
                                Name="EreignisSchreibtischArchivierenButton"
                                Content="Archivieren"
                                Width="140"
                                Height="36"
                                HorizontalAlignment="Left"
                                Visibility="Collapsed"
                                Click="EreignisSchreibtischArchivieren_Click"/>

                        </StackPanel>

                        <GroupBox Grid.Column="2" Header="Meine Ereignisse">

                            <ListBox
                                Name="EreignisListeSchreibtisch"
                                SelectionChanged="EreignisListeSchreibtisch_SelectionChanged"/>

                        </GroupBox>

                    </Grid>

                    <!-- Build 6.0: Die Ereignismappe - erscheint unmittelbar nach
                         dem Anlegen eines neuen Ereignisses. James kehrt bewusst
                         nicht zu einer leeren Eingabemaske zurück. -->
                    <StackPanel
                        Name="EreignismappeBereich"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Visibility="Collapsed"
                        MaxWidth="500"
                        HorizontalAlignment="Left">

                        <TextBlock
                            Name="EreignismappeTitelText"
                            FontSize="18"
                            FontWeight="Bold"
                            TextWrapping="Wrap"
                            Margin="0,0,0,20"/>

                        <TextBlock
                            FontSize="15"
                            TextWrapping="Wrap"
                            Margin="0,0,0,16"
                            Text="Was würden Sie dieser Mappe jetzt gerne hinzufügen?"/>

                        <Button
                            Content="Bilder"
                            Width="300"
                            Height="44"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,10"
                            Click="EreignismappeBilder_Click"/>

                        <Button Content="Dokumente" Width="300" Height="44" HorizontalAlignment="Left" Margin="0,0,0,10" IsEnabled="False"/>
                        <Button Content="Videos" Width="300" Height="44" HorizontalAlignment="Left" Margin="0,0,0,10" IsEnabled="False"/>
                        <Button Content="Kommentare" Width="300" Height="44" HorizontalAlignment="Left" Margin="0,0,0,24" IsEnabled="False"/>

                        <TextBlock
                            Text="◀ Zurück zur Ereignisliste"
                            Foreground="#2E7D32"
                            FontWeight="Bold"
                            TextDecorations="Underline"
                            Cursor="Hand"
                            MouseLeftButtonUp="EreignismappeZurueck_Click"/>

                    </StackPanel>

                    <!-- Eingabebereich: der persönliche Schreibtisch -->

                    <ScrollViewer
                        Grid.Column="0"
                        Name="PersonenFormularBereich"
                        Visibility="Collapsed"
                        VerticalScrollBarVisibility="Auto">
                        <StackPanel>

                            <TextBlock
                                Text="◀ Zur Startseite"
                                Foreground="#2E7D32"
                                FontWeight="Bold"
                                TextDecorations="Underline"
                                Cursor="Hand"
                                Margin="0,0,0,24"
                                MouseLeftButtonUp="ZurStartseite_Click"/>

                            <TextBlock Text="Vorname" Margin="0,0,0,4"/>
                            <TextBox
                                Name="VornameTextBox"
                                Padding="4"
                                Margin="0,0,0,16"/>

                            <TextBlock Text="Nachname" Margin="0,0,0,4"/>
                            <TextBox
                                Name="NachnameTextBox"
                                Padding="4"
                                Margin="0,0,0,16"/>

                            <TextBlock Text="Geburtsdatum" Margin="0,0,0,4"/>
                            <TextBox
                                Name="GeburtTextBox"
                                Padding="4"
                                Margin="0,0,0,16"/>

                            <TextBlock Text="Ort" Margin="0,0,0,4"/>
                            <TextBox
                                Name="OrtTextBox"
                                Padding="4"
                                Margin="0,0,0,16"/>

                            <TextBlock Text="Welche Rolle spielt dieser Mensch in Ihrem Leben?" Margin="0,0,0,4"/>
                            <ComboBox
                                Name="BeziehungRolleComboBox"
                                Width="320"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,16"
                                IsEditable="True"
                                IsTextSearchCaseSensitive="False">
                                <ComboBoxItem Content="Vater"/>
                                <ComboBoxItem Content="Mutter"/>
                                <ComboBoxItem Content="Bruder"/>
                                <ComboBoxItem Content="Schwester"/>
                                <ComboBoxItem Content="Großvater"/>
                                <ComboBoxItem Content="Großmutter"/>
                                <ComboBoxItem Content="Onkel"/>
                                <ComboBoxItem Content="Tante"/>
                                <ComboBoxItem Content="Partner"/>
                                <ComboBoxItem Content="Kind"/>
                                <ComboBoxItem Content="Freund"/>
                                <ComboBoxItem Content="Kollege"/>
                                <ComboBoxItem Content="Nachbar"/>
                                <ComboBoxItem Content="Lehrer"/>
                                <ComboBoxItem Content="Bekannter"/>
                            </ComboBox>

                            <TextBlock
                                FontStyle="Italic"
                                Foreground="#777777"
                                TextWrapping="Wrap"
                                Margin="0,0,0,16"
                                Text="Hier entstehen neue Erinnerungen."/>

                            <WrapPanel>

                                <Button
                                    Name="SpeichernButton"
                                    Content="Speichern"
                                    Width="140"
                                    Height="40"
                                    Margin="0,0,10,10"
                                    Click="Speichern_Click"/>

                                <Button
                                    Name="LoeschenButton"
                                    Content="Löschen"
                                    Width="140"
                                    Height="40"
                                    Margin="0,0,10,10"
                                    Click="Loeschen_Click"/>

                                <Button
                                    Name="BearbeitenButton"
                                    Content="Bearbeiten"
                                    Width="140"
                                    Height="40"
                                    Margin="0,0,10,10"
                                    Click="Bearbeiten_Click"/>

                                <Button
                                    Name="ArchivierenButton"
                                    Content="Archivieren"
                                    Width="140"
                                    Height="40"
                                    Margin="0,0,10,10"
                                    Click="Archivieren_Click"/>

                            </WrapPanel>

                            <TextBlock
                                Name="StatusText"
                                FontWeight="Bold"
                                FontSize="20"
                                Foreground="#2E7D32"
                                TextWrapping="Wrap"
                                Margin="0,10,0,0"
                                Visibility="Collapsed"/>

                            <Border
                                BorderBrush="#CCCCCC"
                                BorderThickness="1"
                                Width="150"
                                Height="150"
                                Margin="0,20,0,10"
                                HorizontalAlignment="Left">
                                <Image
                                    Name="PersonFotoBild"
                                    Stretch="Uniform"/>
                            </Border>

                            <Button
                                Name="FotoHinzufuegenButton"
                                Content="Erinnerungen zuordnen"
                                Width="140"
                                Height="40"
                                HorizontalAlignment="Left"
                                Click="FotoHinzufuegen_Click"/>

                            <!-- Build 2.3/2.9: Eine Person besitzt nicht nur ein Titelbild,
                                 sondern auch die Erinnerungen ihrer Ereignisse. Das
                                 Titelbild bleibt nur "das Gesicht" der Person.
                                 Build 2.9: Anklicken öffnet das einfache Erinnerungsfenster. -->
                            <TextBlock
                                Name="PersonErinnerungenLinkText"
                                Foreground="#2E7D32"
                                FontWeight="Bold"
                                TextDecorations="Underline"
                                Cursor="Hand"
                                Margin="0,14,0,6"
                                MouseLeftButtonUp="PersonErinnerungenLinkText_MouseLeftButtonUp"/>

                            <TextBlock
                                FontWeight="Bold"
                                Margin="0,30,0,4"
                                Text="Ereignisse"/>

                            <ListBox
                                Name="EreignisseListe"
                                Height="100"
                                Margin="0,0,0,10"
                                SelectionChanged="EreignisseListe_SelectionChanged"/>

                            <StackPanel
                                Name="EreignisAuswahlPanel"
                                Visibility="Collapsed"
                                Margin="0,0,0,10">

                                <Border
                                    BorderBrush="#CCCCCC"
                                    BorderThickness="1"
                                    Width="150"
                                    Height="150"
                                    Margin="0,0,0,10"
                                    HorizontalAlignment="Left">
                                    <Image
                                        Name="EreignisFotoBild"
                                        Stretch="Uniform"/>
                                </Border>

                                <TextBlock
                                    Name="EreignisDetailsText"
                                    TextWrapping="Wrap"
                                    Foreground="#555555"
                                    Margin="0,0,0,10"/>

                                <!-- Build 2.9: Anklicken öffnet das einfache
                                     Erinnerungsfenster, beschränkt auf dieses Ereignis. -->
                                <TextBlock
                                    Name="EreignisErinnerungenLinkText"
                                    Foreground="#2E7D32"
                                    FontWeight="Bold"
                                    TextDecorations="Underline"
                                    Cursor="Hand"
                                    Margin="0,0,0,10"
                                    MouseLeftButtonUp="EreignisErinnerungenLinkText_MouseLeftButtonUp"/>

                                <Button
                                    Name="EreignisFotoHinzufuegenButton"
                                    Content="Erinnerungen zu diesem Ereignis zuordnen"
                                    Width="240"
                                    Height="40"
                                    HorizontalAlignment="Left"
                                    Margin="0,0,0,20"
                                    Click="EreignisFotoHinzufuegen_Click"/>

                                <TextBlock
                                    FontWeight="Bold"
                                    Margin="0,0,0,8"
                                    Text="Diese Erinnerung bewerten"/>

                                <CheckBox Name="BewertungFavoritCheckBox" Content="⭐ Favorit" Margin="0,0,0,6"/>
                                <CheckBox Name="BewertungWichtigCheckBox" Content="⭐ Besonders wichtig" Margin="0,0,0,6"/>
                                <CheckBox Name="BewertungFamiliengeschichteCheckBox" Content="⭐ Familiengeschichte" Margin="0,0,0,6"/>
                                <CheckBox Name="BewertungLebensbuchCheckBox" Content="⭐ Für das Lebensbuch geeignet" Margin="0,0,0,6"/>
                                <CheckBox Name="BewertungUeberpruefenCheckBox" Content="⭐ Noch überprüfen" Margin="0,0,0,6"/>
                                <CheckBox Name="BewertungPrivatCheckBox" Content="⭐ Privat" Margin="0,0,0,6"/>
                                <CheckBox Name="BewertungUnbekanntCheckBox" Content="⭐ Unbekannt" Margin="0,0,0,10"/>

                                <Button
                                    Name="BewertungSpeichernButton"
                                    Content="Bewertung speichern"
                                    Width="200"
                                    Height="40"
                                    HorizontalAlignment="Left"
                                    Click="BewertungSpeichern_Click"/>

                            </StackPanel>

                            <Button
                                Name="EreignisHinzufuegenButton"
                                Content="Ereignis hinzufügen"
                                Width="180"
                                Height="40"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,10"
                                Click="EreignisHinzufuegen_Click"/>

                            <StackPanel
                                Name="EreignisFormularPanel"
                                Visibility="Collapsed">

                                <TextBlock Text="Titel" Margin="0,0,0,4"/>
                                <TextBox
                                    Name="EreignisTitelTextBox"
                                    Padding="4"
                                    Margin="0,0,0,10"/>

                                <TextBlock Text="Beschreibung" Margin="0,0,0,4"/>
                                <TextBox
                                    Name="EreignisBeschreibungTextBox"
                                    Padding="4"
                                    Margin="0,0,0,10"
                                    TextWrapping="Wrap"
                                    AcceptsReturn="True"
                                    Height="60"/>

                                <TextBlock Text="Datum" Margin="0,0,0,4"/>
                                <TextBox
                                    Name="EreignisDatumTextBox"
                                    Padding="4"
                                    Margin="0,0,0,10"/>

                                <TextBlock Text="Ort" Margin="0,0,0,4"/>
                                <TextBox
                                    Name="EreignisOrtTextBox"
                                    Padding="4"
                                    Margin="0,0,0,10"/>

                                <TextBlock Text="Jahreszeit" Margin="0,0,0,4"/>
