                                        Content="In den Papierkorb legen"
                                        Width="220"
                                        Height="36"
                                        Margin="0,0,0,16"
                                        HorizontalAlignment="Left"
                                        Click="ArchivPersonInPapierkorb_Click"/>

                                        <TextBlock
                                        FontStyle="Italic"
                                        Foreground="#999999"
                                        TextWrapping="Wrap"
                                        Margin="0,0,0,4"
                                        Text="Folgt später:"/>

                                        <Button
                                        Content="Mit einem Ereignis verknüpfen"
                                        Width="220"
                                        Height="36"
                                        Margin="0,0,0,8"
                                        HorizontalAlignment="Left"
                                        IsEnabled="False"/>

                                        <Button
                                        Content="Im Lebensbuch verlinken"
                                        Width="220"
                                        Height="36"
                                        Margin="0,0,0,8"
                                        HorizontalAlignment="Left"
                                        IsEnabled="False"/>

                                        <Button
                                        Content="In andere Datei verschieben"
                                        Width="220"
                                        Height="36"
                                        HorizontalAlignment="Left"
                                        IsEnabled="False"/>

                                    </StackPanel>

                                </StackPanel>

                            </Grid>

                        </GroupBox>

                        <!-- Build 6.0, Punkt 6: Das Archiv unterscheidet jetzt
                             zwischen Personen und Ereignissen - beide arbeiten
                             nach derselben Bedienlogik. -->
                        <GroupBox
                            Grid.Column="2"
                            Header="Archivierte Ereignisse">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="200"/>
