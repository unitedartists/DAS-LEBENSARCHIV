                                        <Button
                                        Content="Zurück auf den Schreibtisch"
                                        Width="220"
                                        Height="36"
                                        Margin="0,0,0,8"
                                        HorizontalAlignment="Left"
                                        Click="ArchivZurueck_Click"/>

                                        <!-- Etappe B.1b, Punkt 4: dieselbe Papierkorb-Logik
                                             wie beim Ereignis-Archiv, statt sofortiger,
                                             endgültiger Entfernung. -->
