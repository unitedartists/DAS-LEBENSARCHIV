                                    SelectionChanged="ArchivEreignisseListe_SelectionChanged"/>

                                <StackPanel Grid.Column="2">

                                    <!-- Etappe B.1b, Punkt 1+3: dasselbe Bedienprinzip
                                         wie beim Personen-Archiv - ein Menü statt
