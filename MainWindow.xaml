                            Click="EinstellungenSpeichern_Click"/>

                            <TextBlock
                            Name="EinstellungenStatusText"
                            FontWeight="Bold"
                            Foreground="#2E7D32"
                            TextWrapping="Wrap"
                            Margin="0,14,0,0"/>

                        </StackPanel>

                    </Grid>

                </ScrollViewer>

            </TabItem>

            <TabItem Header="Arbeitsmappe">

                <Grid Margin="30">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Kopfbereich: James' Begrüßung + Filter + Suche -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,14">

                        <TextBlock
                            Name="ArbeitsmappeUeberschriftText"
                            FontSize="16"
                            FontWeight="Bold"
                            TextWrapping="Wrap"
                            Margin="0,0,0,14"/>

                        <!-- Build 2.8, Punkt 4: Debug-Anzeige, ob/wann
                             OeffneArbeitsmappe() tatsächlich ausgeführt wird -
                             bleibt bewusst dauerhaft sichtbar. -->
                        <TextBlock
                            Name="ArbeitsmappeDebugText"
                            FontSize="11"
                            FontStyle="Italic"
                            Foreground="#B00020"
                            Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">

                            <Button Name="ArbeitsmappeFilterAlleButton" Content="Alle" Tag="Alle" Padding="10,4" Margin="0,0,8,0" Click="ArbeitsmappeFilter_Click"/>
                            <Button Name="ArbeitsmappeFilterBilderButton" Content="Bilder" Tag="Bilder" Padding="10,4" Margin="0,0,8,0" Click="ArbeitsmappeFilter_Click"/>
                            <Button Name="ArbeitsmappeFilterDokumenteButton" Content="Dokumente" Tag="Dokumente" Padding="10,4" Margin="0,0,8,0" Click="ArbeitsmappeFilter_Click"/>
                            <Button Name="ArbeitsmappeFilterPdfButton" Content="PDF" Tag="PDF" Padding="10,4" Margin="0,0,8,0" Click="ArbeitsmappeFilter_Click"/>
                            <Button Name="ArbeitsmappeFilterVideosButton" Content="Videos" Tag="Videos" Padding="10,4" Margin="0,0,8,0" Click="ArbeitsmappeFilter_Click"/>
                            <Button Name="ArbeitsmappeFilterAudioButton" Content="Audio" Tag="Audio" Padding="10,4" Margin="0,0,8,0" Click="ArbeitsmappeFilter_Click"/>

                        </StackPanel>

                        <TextBlock Text="Nach Dateiname suchen" Margin="0,0,0,4"/>
                        <TextBox
                            Name="ArbeitsmappeSucheTextBox"
                            Width="320"
                            HorizontalAlignment="Left"
                            Padding="4"
                            TextChanged="ArbeitsmappeSucheTextBox_TextChanged"/>

                    </StackPanel>

                    <!-- Seitennavigation -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Name="ArbeitsmappeVorherigeSeiteButton" Content="◀ Vorherige Seite" Padding="10,4" Margin="0,0,10,0" Click="ArbeitsmappeVorherigeSeite_Click"/>
                        <TextBlock Name="ArbeitsmappeSeiteText" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Button Name="ArbeitsmappeNaechsteSeiteButton" Content="Nächste Seite ▶" Padding="10,4" Click="ArbeitsmappeNaechsteSeite_Click"/>
                    </StackPanel>

                    <!-- Hauptbereich: Kacheln links, Werkzeuge rechts -->
                    <Grid Grid.Row="2">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="240"/>
                        </Grid.ColumnDefinitions>

                        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                            <WrapPanel Name="ArbeitsmappeKachelnPanel"/>
                        </ScrollViewer>

                        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                            <StackPanel>

                                <TextBlock
                                Name="ArbeitsmappeAuswahlText"
                                FontWeight="Bold"
                                TextWrapping="Wrap"
                                Margin="0,0,0,14"/>

                                <!-- Build 2.2 "Erinnerungen zuerst": geführter Arbeitsablauf.
                                 James führt den Benutzer, statt ihn zwischen Reitern
                                 hin- und herspringen zu lassen (James-Regel Nr. 2). -->

                                <Button
                                Name="ArbeitsmappeNeuesEreignisAnlegenButton"
                                Content="Neues Ereignis anlegen"
                                Width="200"
                                Height="36"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,8"
                                IsEnabled="False"
                                Click="ArbeitsmappeNeuesEreignisAnlegen_Click"/>

                                <Button
                                Name="ArbeitsmappeMitEreignisVerbindenButton"
                                Content="Vorhandenem Ereignis zuordnen"
                                Width="200"
                                Height="36"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,8"
                                IsEnabled="False"
                                Click="ArbeitsmappeMitEreignisVerbinden_Click"/>

                                <Button
                                Name="ArbeitsmappeNeuePersonAnlegenButton"
                                Content="Neue Person anlegen"
                                Width="200"
                                Height="36"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,8"
                                IsEnabled="False"
                                Click="ArbeitsmappeNeuePersonAnlegen_Click"/>

                                <Button
                                Name="ArbeitsmappePersonZuordnenButton"
                                Content="Erinnerungen zuordnen"
                                Width="200"
                                Height="36"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,8"
                                IsEnabled="False"
                                Click="ArbeitsmappePersonZuordnen_Click"/>

                                <Button
                                Name="ArbeitsmappeMarkierungAufhebenButton"
                                Content="Markierung aufheben"
                                Width="200"
                                Height="36"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,20"
                                IsEnabled="False"
                                Click="ArbeitsmappeMarkierungAufheben_Click"/>

                                <!-- Build 5.0 "Erinnerungen über Personen ODER Ereignisse":
                                 Ein "freies" Ereignis ist eigenständig, unabhängig von
                                 jeder Person. James macht dabei keine eigenen
                                 Namensvorschläge - der Benutzer vergibt den Namen
                                 selbst, und nur selbst angelegte Ereignisse erscheinen
                                 später zur Auswahl. -->
                                <TextBlock
                                FontWeight="Bold"
                                Margin="0,0,0,4"
                                Text="Ereignis"/>

                                <Button
                                Name="ArbeitsmappeNeuesFreiesEreignisButton"
                                Content="Neues Ereignis anlegen"
                                Width="200"
                                Height="36"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,8"
                                IsEnabled="False"
                                Click="ArbeitsmappeNeuesFreiesEreignisAnlegen_Click"/>

                                <Button
                                Name="ArbeitsmappeFreiesEreignisZuordnenButton"
                                Content="Vorhandenem Ereignis zuordnen"
                                Width="200"
                                Height="36"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,20"
                                IsEnabled="False"
                                Click="ArbeitsmappeFreiesEreignisZuordnen_Click"/>

                                <TextBlock
                                FontStyle="Italic"
                                Foreground="#999999"
                                TextWrapping="Wrap"
                                Margin="0,0,0,4"
                                Text="Folgt später:"/>

                                <Button Content="In die Asservatenkammer legen" Width="200" Height="32" HorizontalAlignment="Left" Margin="0,0,0,20" IsEnabled="False"/>

                                <!-- Build 5.0: Übersicht aller vom Benutzer selbst
                                 angelegten, freien Ereignisse. -->
                                <TextBlock
                                FontWeight="Bold"
                                Margin="0,0,0,4"
                                Text="Meine besonderen Ereignisse"/>

                                <ListBox
                                Name="FreieEreignisseListe"
                                Height="120"
                                Margin="0,0,0,8"
                                SelectionMode="Extended"
                                SelectionChanged="FreieEreignisseListe_SelectionChanged"/>

                                <Button
                                Name="FreiesEreignisErinnerungenAnsehenButton"
                                Content="Erinnerungen ansehen"
                                Width="200"
                                Height="32"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,8"
                                IsEnabled="False"
                                Click="FreiesEreignisErinnerungenAnsehen_Click"/>

                                <Button
                                Name="FreiesEreignisArchivierenButton"
                                Content="Archivieren"
                                Width="200"
                                Height="32"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,8"
                                IsEnabled="False"
                                Click="FreiesEreignisArchivieren_Click"/>

                                <!-- Etappe A.5, Punkt 2: dieselbe Papierkorb-Logik
                                 wie bei Personen. -->
                                <Button
                                Name="FreiesEreignisInPapierkorbButton"
                                Content="In den Papierkorb legen"
                                Width="200"
                                Height="32"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,20"
                                IsEnabled="False"
                                Click="FreiesEreignisInPapierkorb_Click"/>

                                <!-- Inline-Auswahl: Vorhandenem Ereignis zuordnen -->
                                <StackPanel Name="ArbeitsmappeEreignisAuswahlPanel" Visibility="Collapsed" Margin="0,20,0,0">

                                    <TextBlock Text="Mit welchem Ereignis verbinden?" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,8"/>

                                    <TextBlock Text="Person" Margin="0,0,0,4"/>
                                    <ComboBox Name="ArbeitsmappePersonComboBox" Margin="0,0,0,10" SelectionChanged="ArbeitsmappePersonComboBox_SelectionChanged"/>

                                    <TextBlock Text="Ereignis" Margin="0,0,0,4"/>
                                    <ComboBox Name="ArbeitsmappeEreignisComboBox" Margin="0,0,0,10"/>

                                    <Button
                                    Name="ArbeitsmappeEreignisBestaetigenButton"
                                    Content="Verbinden"
                                    Width="140"
                                    Height="36"
                                    HorizontalAlignment="Left"
                                    Click="ArbeitsmappeEreignisBestaetigen_Click"/>

                                </StackPanel>

                                <!-- Inline-Auswahl: Neues Ereignis - erst die Person klären -->
                                <StackPanel Name="ArbeitsmappeNeuesEreignisPersonPanel" Visibility="Collapsed" Margin="0,20,0,0">

                                    <TextBlock Text="Zu welcher Person soll das neue Ereignis gehören?" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,8"/>

                                    <ComboBox Name="ArbeitsmappeNeuesEreignisPersonComboBox" Margin="0,0,0,10"/>

                                    <Button
                                    Name="ArbeitsmappeNeuesEreignisWeiterButton"
                                    Content="Weiter"
                                    Width="140"
                                    Height="36"
                                    HorizontalAlignment="Left"
                                    Click="ArbeitsmappeNeuesEreignisWeiter_Click"/>

                                </StackPanel>

                                <!-- Inline-Auswahl: Vorhandener Person zuordnen -->
                                <StackPanel Name="ArbeitsmappePersonAuswahlPanel" Visibility="Collapsed" Margin="0,20,0,0">

                                    <TextBlock Text="Welcher Person zuordnen?" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,8"/>

                                    <ComboBox Name="ArbeitsmappeTitelbildPersonComboBox" Margin="0,0,0,10" SelectionChanged="ArbeitsmappeTitelbildPersonComboBox_SelectionChanged"/>

                                    <Button
                                    Name="ArbeitsmappeTitelbildBestaetigenButton"
                                    Content="Zuordnen"
                                    Width="140"
                                    Height="36"
                                    HorizontalAlignment="Left"
                                    Click="ArbeitsmappeTitelbildBestaetigen_Click"/>

                                </StackPanel>

                                <!-- Build 2.2a: Neues Ereignis - Formular komplett inline,
                                 kein Wechsel zum Schreibtisch mehr. -->
                                <StackPanel Name="ArbeitsmappeNeuesEreignisFormularPanel" Visibility="Collapsed" Margin="0,20,0,0">

                                    <TextBlock Text="Neues Ereignis" FontWeight="Bold" Margin="0,0,0,8"/>

                                    <TextBlock Text="Titel" Margin="0,0,0,4"/>
                                    <TextBox Name="ArbeitsmappeEreignisTitelTextBox" Padding="4" Margin="0,0,0,8"/>

                                    <TextBlock Text="Beschreibung" Margin="0,0,0,4"/>
                                    <TextBox Name="ArbeitsmappeEreignisBeschreibungTextBox" Padding="4" TextWrapping="Wrap" AcceptsReturn="True" Height="50" Margin="0,0,0,8"/>

                                    <TextBlock Text="Datum" Margin="0,0,0,4"/>
                                    <TextBox Name="ArbeitsmappeEreignisDatumTextBox" Padding="4" Margin="0,0,0,8"/>

                                    <TextBlock Text="Ort" Margin="0,0,0,4"/>
                                    <TextBox Name="ArbeitsmappeEreignisOrtTextBox" Padding="4" Margin="0,0,0,8"/>

                                    <TextBlock Text="Jahreszeit" Margin="0,0,0,4"/>
                                    <ComboBox Name="ArbeitsmappeEreignisJahreszeitComboBox" SelectedIndex="0" Margin="0,0,0,8">
                                        <ComboBoxItem Content=""/>
                                        <ComboBoxItem Content="Frühling"/>
                                        <ComboBoxItem Content="Sommer"/>
                                        <ComboBoxItem Content="Herbst"/>
                                        <ComboBoxItem Content="Winter"/>
                                    </ComboBox>

                                    <TextBlock Text="Stichwörter (durch Komma getrennt)" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                    <TextBox Name="ArbeitsmappeEreignisStichwoerterTextBox" Padding="4" Margin="0,0,0,8"/>

                                    <TextBlock Text="Bemerkungen" Margin="0,0,0,4"/>
                                    <TextBox Name="ArbeitsmappeEreignisBemerkungenTextBox" Padding="4" TextWrapping="Wrap" AcceptsReturn="True" Height="50" Margin="0,0,0,8"/>

                                    <TextBlock Text="Wer war noch dabei? (durch Komma getrennt)" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                    <TextBox Name="ArbeitsmappeEreignisBeteiligteTextBox" Padding="4" Margin="0,0,0,10"/>

                                    <Button
                                    Name="ArbeitsmappeEreignisSpeichernButton"
                                    Content="Ereignis speichern"
                                    Width="160"
                                    Height="36"
                                    HorizontalAlignment="Left"
                                    Click="ArbeitsmappeEreignisSpeichern_Click"/>

                                </StackPanel>

                                <!-- Build 2.2a: Neue Person - Formular komplett inline,
                                 kein Wechsel zum Schreibtisch mehr. -->
                                <StackPanel Name="ArbeitsmappeNeuePersonPanel" Visibility="Collapsed" Margin="0,20,0,0">

                                    <TextBlock Text="Neue Person" FontWeight="Bold" Margin="0,0,0,8"/>

                                    <TextBlock Text="Vorname" Margin="0,0,0,4"/>
                                    <TextBox Name="ArbeitsmappeNeuePersonVornameTextBox" Padding="4" Margin="0,0,0,8"/>

                                    <TextBlock Text="Nachname" Margin="0,0,0,4"/>
                                    <TextBox Name="ArbeitsmappeNeuePersonNachnameTextBox" Padding="4" Margin="0,0,0,8"/>

                                    <TextBlock Text="Geburtsdatum" Margin="0,0,0,4"/>
                                    <TextBox Name="ArbeitsmappeNeuePersonGeburtTextBox" Padding="4" Margin="0,0,0,8"/>

                                    <TextBlock Text="Ort" Margin="0,0,0,4"/>
                                    <TextBox Name="ArbeitsmappeNeuePersonOrtTextBox" Padding="4" Margin="0,0,0,8"/>

                                    <TextBlock Text="Welche Rolle spielt dieser Mensch in Ihrem Leben?" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                    <ComboBox
                                    Name="ArbeitsmappeNeuePersonBeziehungComboBox"
                                    IsEditable="True"
                                    IsTextSearchCaseSensitive="False"
                                    Margin="0,0,0,10">
                                        <ComboBoxItem Content="Vater"/>
                                        <ComboBoxItem Content="Mutter"/>
                                        <ComboBoxItem Content="Bruder"/>
                                        <ComboBoxItem Content="Schwester"/>
                                        <ComboBoxItem Content="Großvater"/>
                                        <ComboBoxItem Content="Großmutter"/>
                                        <ComboBoxItem Content="Onkel"/>
                                        <ComboBoxItem Content="Tante"/>
                                        <ComboBoxItem Content="Partner"/>
                                        <ComboBoxItem Content="Kind"/>
                                        <ComboBoxItem Content="Freund"/>
                                        <ComboBoxItem Content="Kollege"/>
                                        <ComboBoxItem Content="Nachbar"/>
                                        <ComboBoxItem Content="Lehrer"/>
                                        <ComboBoxItem Content="Bekannter"/>
                                    </ComboBox>

                                    <Button
                                    Name="ArbeitsmappeNeuePersonSpeichernButton"
                                    Content="Person speichern"
                                    Width="160"
                                    Height="36"
                                    HorizontalAlignment="Left"
                                    Click="ArbeitsmappeNeuePersonSpeichern_Click"/>

                                </StackPanel>

                                <!-- Build 5.0: Neues freies Ereignis - James macht
                                 keine Namensvorschläge, der Benutzer vergibt den
                                 Namen selbst. -->
                                <StackPanel Name="ArbeitsmappeNeuesFreiesEreignisPanel" Visibility="Collapsed" Margin="0,20,0,0">

                                    <TextBlock Text="Neues Ereignis" FontWeight="Bold" Margin="0,0,0,8"/>

                                    <TextBlock Text="Ereignis" Margin="0,0,0,4"/>
                                    <TextBox Name="FreiesEreignisTitelTextBox" Padding="4" Margin="0,0,0,10"/>

                                    <Button
                                    Name="FreiesEreignisSpeichernButton"
                                    Content="Speichern und zuordnen"
                                    Width="180"
                                    Height="36"
                                    HorizontalAlignment="Left"
                                    Click="FreiesEreignisSpeichernUndZuordnen_Click"/>

                                </StackPanel>

                                <!-- Build 5.0: Vorhandenem freien Ereignis zuordnen -
                                 die Auswahlliste enthält ausschließlich bereits
                                 vom Benutzer selbst angelegte, freie Ereignisse. -->
                                <StackPanel Name="ArbeitsmappeFreiesEreignisAuswahlPanel" Visibility="Collapsed" Margin="0,20,0,0">

                                    <TextBlock Text="Welchem Ereignis zuordnen?" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,8"/>

                                    <ComboBox Name="FreiesEreignisComboBox" Margin="0,0,0,10"/>

                                    <Button
                                    Name="FreiesEreignisZuordnenBestaetigenButton"
                                    Content="Zuordnen"
                                    Width="140"
                                    Height="36"
                                    HorizontalAlignment="Left"
                                    Click="FreiesEreignisBestaetigen_Click"/>

                                </StackPanel>

                                <TextBlock
                                Name="ArbeitsmappeStatusText"
                                FontWeight="Bold"
                                Foreground="#2E7D32"
                                TextWrapping="Wrap"
                                Margin="0,20,0,0"/>

                                <!-- Build 2.3, Punkt 1: optionales Öffnen des zuletzt
                                 angelegten/verbundenen Ereignisses - die Arbeitsmappe
                                 wird dabei NICHT automatisch verlassen, nur auf
                                 ausdrücklichen Wunsch des Benutzers. -->
                                <Button
                                Name="ArbeitsmappeEreignisOeffnenButton"
                                Content="Ereignis öffnen"
                                Width="160"
                                Height="34"
                                HorizontalAlignment="Left"
                                Margin="0,10,0,0"
                                Visibility="Collapsed"
                                Click="ArbeitsmappeEreignisOeffnen_Click"/>

                            </StackPanel>
                        </ScrollViewer>

                    </Grid>

                    <!-- Großansicht (nur für Bilder), deckt den ganzen Reiter ab -->
                    <Border
                        Grid.Row="0"
                        Grid.RowSpan="3"
                        Name="ArbeitsmappeGrossansichtPanel"
                        Visibility="Collapsed"
                        Background="#F0000000">

                        <Grid Margin="20">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Button
                                Grid.Row="0"
                                Content="◀ Zurück zur Arbeitsmappe"
                                Width="220"
                                Height="36"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,10"
                                Click="ArbeitsmappeGrossansichtSchliessen_Click"/>

                            <Image
                                Grid.Row="1"
                                Name="ArbeitsmappeGrossBild"
                                Stretch="Uniform"/>

                        </Grid>

                    </Border>

                </Grid>

            </TabItem>

        </TabControl>

    </DockPanel>

</Window>
