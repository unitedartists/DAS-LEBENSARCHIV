                        <StackPanel Grid.Row="2" Margin="0,0,0,20">

                            <TextBlock
                            FontWeight="Bold"
                            Margin="0,0,0,4"
                            Text="Computer kennenlernen"/>

                            <TextBlock
                            TextWrapping="Wrap"
                            Foreground="#555555"
                            Margin="0,0,0,12"
                            Text="James kann ausgewählte Ordner sorgfältig durchsuchen, um herauszufinden, welche Erinnerungen vorhanden sind. Dabei wird nichts verändert, verschoben oder gelöscht - James verschafft sich zunächst nur einen Überblick, und nur dort, wo Sie es erlauben."/>

                            <Button
