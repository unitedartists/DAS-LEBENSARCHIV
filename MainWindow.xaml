                                            Height="36"
                                            Margin="0,0,0,8"
                                            HorizontalAlignment="Left"
                                            Click="ArchivEreignisErinnerungenAnsehen_Click"/>

                                        <!-- Etappe B.1b, Punkt 5: einheitlich benannt wie
                                             beim Personen-Archiv (statt "Zurück in die Liste"). -->
                                        <Button
                                            Name="ArchivEreignisWiederherstellenButton"
                                            Content="Zurück auf den Schreibtisch"
                                            Width="180"
                                            Height="36"
                                            Margin="0,0,0,8"
                                            HorizontalAlignment="Left"
                                            Click="ArchivEreignisWiederherstellen_Click"/>

                                        <Button
                                            Name="ArchivEreignisInPapierkorbButton"
                                            Content="In den Papierkorb legen"
                                            Width="180"
                                            Height="36"
                                            HorizontalAlignment="Left"
                                            Click="ArchivEreignisInPapierkorb_Click"/>

                                    </StackPanel>

                                </StackPanel>

                            </Grid>

                        </GroupBox>

                    </Grid>

                </Grid>

            </TabItem>

